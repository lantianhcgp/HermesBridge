<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true">

    <!-- ========== TopAppBar ========== -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:elevation="0dp"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Hermes Bridge"
            app:titleTextColor="?attr/colorOnSurface"
            app:titleTextAppearance="?attr/textAppearanceTitleLarge"
            app:subtitle="AI Agent 桥接服务"
            app:subtitleTextColor="?attr/colorOnSurfaceVariant"
            app:subtitleTextAppearance="?attr/textAppearanceBodyMedium"
            app:menu="@menu/menu_main" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ========== Main Content ========== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- ========== Hero Status Card ========== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:strokeColor="@android:color/transparent"
                app:cardBackgroundColor="?attr/colorSurfaceContainerLow">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingHorizontal="24dp"
                    android:paddingTop="28dp"
                    android:paddingBottom="24dp">

                    <!-- App Icon in tonal container -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="?attr/colorPrimaryContainer">

                        <ImageView
                            android:id="@+id/ivAppIcon"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:src="@mipmap/ic_launcher"
                            android:contentDescription="@string/app_name"
                            app:tint="?attr/colorOnPrimaryContainer" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Title -->
                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hermes Bridge"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp" />

                    <!-- Version + Status chip row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <!-- Version badge -->
                        <TextView
                            android:id="@+id/tvVersion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="v2.5"
                            android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:background="?attr/colorSurfaceContainerHighest"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp" />

                        <View
                            android:layout_width="8dp"
                            android:layout_height="0dp" />

                        <!-- Status chip -->
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="已停止"
                            android:textAppearance="?attr/textAppearanceLabelMedium"
                            app:chipMinHeight="32dp"
                            app:chipCornerRadius="16dp"
                            app:chipBackgroundColor="?attr/colorErrorContainer"
                            app:textStartPadding="8dp"
                            app:textEndPadding="8dp"
                            app:chipStrokeWidth="0dp"
                            tools:chipBackgroundColor="#C2E9E1"
                            tools:text="运行中"
                            tools:textColor="#1A3733" />
                    </LinearLayout>

                    <!-- Port info -->
                    <TextView
                        android:id="@+id/tvPort"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="端口: 8889"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginTop="8dp" />

                    <!-- ========== Start/Stop Buttons ========== -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginTop="20dp">

                        <!-- Start Button (Filled Tonal) -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnStart"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="启动服务"
                            android:textAppearance="?attr/textAppearanceLabelLarge"
                            app:cornerRadius="26dp"
                            app:backgroundTint="?attr/colorPrimaryContainer"
                            android:textColor="?attr/colorOnPrimaryContainer"
                            app:icon="@drawable/ic_play"
                            app:iconTint="?attr/colorOnPrimaryContainer"
                            app:iconGravity="textStart"
                            style="@style/Widget.Material3.Button.TonalButton" />

                        <!-- Stop Button (Outlined, Error) -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnStop"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="停止服务"
                            android:textAppearance="?attr/textAppearanceLabelLarge"
                            app:cornerRadius="26dp"
                            app:strokeColor="?attr/colorError"
                            app:strokeWidth="1dp"
                            app:icon="@drawable/ic_stop"
                            app:iconTint="?attr/colorError"
                            app:iconGravity="textStart"
                            android:textColor="?attr/colorError"
                            app:rippleColor="?attr/colorErrorContainer"
                            style="@style/Widget.Material3.Button.OutlinedButton" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ========== Features Section Header ========== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="功能模块"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textStyle="bold"
                android:layout_marginStart="4dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <!-- ========== Feature Grid (3×3) ========== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <!-- 📅 Calendar -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileCalendar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:paddingVertical="16dp"
                            android:paddingHorizontal="8dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                app:cardCornerRadius="14dp"
                                app:cardElevation="0dp"
                                app:strokeWidth="0dp"
                                app:cardBackgroundColor="?attr/colorSecondaryContainer">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="📅"
                                    android:textSize="20sp" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="日历"
                                android:textAppearance="?attr/textAppearanceLabelLarge"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginTop="10dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="日程管理"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 💬 SMS -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileSms"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="3dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:paddingVertical="16dp"
                            android:paddingHorizontal="8dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                app:cardCornerRadius="14dp"
                                app:cardElevation="0dp"
                                app:strokeWidth="0dp"
                                app:cardBackgroundColor="?attr/colorTertiaryContainer">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="💬"
                                    android:textSize="20sp" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="短信"
                                android:textAppearance="?attr/textAppearanceLabelLarge"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginTop="10dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="发送短信"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 🔔 Notification -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileNotify"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:paddingVertical="16dp"
                            android:paddingHorizontal="8dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                app:cardCornerRadius="14dp"
                                app:cardElevation="0dp"
                                app:strokeWidth="0dp"
                                app:cardBackgroundColor="?attr/colorPrimaryContainer">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="🔔"
                                    android:textSize="20sp" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="通知"
                                android:textAppearance="?attr/textAppearanceLabelLarge"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginTop="10dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="推送通知"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <!-- 📍 Location -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileLocation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:paddingVertical="16dp"
                            android:paddingHorizontal="8dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                app:cardCornerRadius="14dp"
                                app:cardElevation="0dp"
                                app:strokeWidth="0dp"
                                app:cardBackgroundColor="?attr/colorErrorContainer">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="📍"
                                    android:textSize="20sp" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="位置"
                                android:textAppearance="?attr/textAppearanceLabelLarge"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginTop="10dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GPS 定位"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 📱 Device -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileDevice"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="3dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:paddingVertical="16dp"
                            android:paddingHorizontal="8dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                app:cardCornerRadius="14dp"
                                app:cardElevation="0dp"
                                app:strokeWidth="0dp"
                                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="📱"
                                    android:textSize="20sp" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="设备"
                                android:textAppearance="?attr/textAppearanceLabelLarge"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginTop="10dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="设备信息"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 👥 Contacts -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileContacts"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:paddingVertical="16dp"
                            android:paddingHorizontal="8dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                app:cardCornerRadius="14dp"
                                app:cardElevation="0dp"
                                app:strokeWidth="0dp"
                                app:cardBackgroundColor="?attr/colorSecondaryContainer">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="👥"
                                    android:textSize="20sp" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="通讯录"
                                android:textAppearance="?attr/textAppearanceLabelLarge"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginTop="10dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="联系人"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Row 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- 📋 Clipboard -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileClipboard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:paddingVertical="16dp"
                            android:paddingHorizontal="8dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                app:cardCornerRadius="14dp"
                                app:cardElevation="0dp"
                                app:strokeWidth="0dp"
                                app:cardBackgroundColor="?attr/colorTertiaryContainer">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="📋"
                                    android:textSize="20sp" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="剪贴板"
                                android:textAppearance="?attr/textAppearanceLabelLarge"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginTop="10dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="读写剪贴"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- ⏰ Alarm -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileAlarm"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="3dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:paddingVertical="16dp"
                            android:paddingHorizontal="8dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                app:cardCornerRadius="14dp"
                                app:cardElevation="0dp"
                                app:strokeWidth="0dp"
                                app:cardBackgroundColor="?attr/colorPrimaryContainer">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="⏰"
                                    android:textSize="20sp" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="闹钟"
                                android:textAppearance="?attr/textAppearanceLabelLarge"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginTop="10dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="定时闹钟"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 📶 WiFi -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileWifi"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:paddingVertical="16dp"
                            android:paddingHorizontal="8dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                app:cardCornerRadius="14dp"
                                app:cardElevation="0dp"
                                app:strokeWidth="0dp"
                                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="📶"
                                    android:textSize="20sp" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="WiFi"
                                android:textAppearance="?attr/textAppearanceLabelLarge"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginTop="10dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="网络信息"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>

            <!-- ========== Footer ========== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hermes Agent · Android 桥接服务"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOutline"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
